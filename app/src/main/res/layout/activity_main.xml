<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgView"
    tools:context=".MainActivity">

    <!-- Barra de búsqueda -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center"
        android:background="@drawable/bg_input"
        android:layout_margin="15dp"
        android:padding="5dp"
        android:elevation="4dp">

        <ImageView
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginStart="10dp"
            android:src="@drawable/ic_magnifying_glass"/>

        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Buscar funcionalidad..."
            android:textSize="14sp"
            android:textColorHint="@color/gray"
            app:fontVariationSettings="'wght' 600"
            android:singleLine="true"
            android:ellipsize="end"
            android:scrollHorizontally="true"
            android:paddingTop="10dp"
            android:paddingLeft="10dp"
            android:layout_marginBottom="3dp"
            android:background="@drawable/bg_input"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="60dp"
        android:padding="15dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:paddingLeft="15dp"
                android:paddingRight="15dp"
                android:paddingBottom="10dp"
                android:orientation="vertical"
                android:background="@drawable/bg_input">

                <!-- Ubicacion actual - Header -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:src="@drawable/ic_map_pin"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estación de monitoreo 1"
                        android:textColor="@color/black"
                        app:fontVariationSettings="'wght' 700"
                        android:paddingTop="10dp"
                        android:paddingBottom="6dp"
                        android:paddingLeft="3dp"/>
                </LinearLayout>

                <!-- Temperatura -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Temperatura actual -->
                    <TextView
                        android:id="@+id/actualTemp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="@color/black"
                        android:textSize="50sp"
                        app:fontVariationSettings="'wght' 700"/>

                    <!-- Temperatura maxima y minima -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginLeft="10dp">

                        <!-- Temperatura maxima -->
                        <TextView
                            android:id="@+id/actualMaxTemp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MAX: -"
                            android:textColor="@color/black"
                            android:textSize="18sp"
                            app:fontVariationSettings="'wght' 500"/>

                        <!-- Temperatura minima -->
                        <TextView
                            android:id="@+id/actualMinTemp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MIN: -"
                            android:textColor="@color/black"
                            android:textSize="18sp"
                            app:fontVariationSettings="'wght' 500"/>
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/lightGray"/>

                <!-- Variables del clima -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <!-- Variable humedad -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Humedad"
                            android:textColor="@color/gray"
                            app:fontVariationSettings="'wght' 400"/>

                        <TextView
                            android:id="@+id/actualHumidity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="@color/black"
                            app:fontVariationSettings="'wght' 600"/>
                    </LinearLayout>

                    <!-- Variable pH -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginLeft="15dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Acidez (pH)"
                            android:textColor="@color/gray"
                            app:fontVariationSettings="'wght' 400"/>

                        <TextView
                            android:id="@+id/actualPh"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="@color/black"
                            app:fontVariationSettings="'wght' 600"/>
                    </LinearLayout>

                    <!-- Variable electroconductividad -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginLeft="15dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EC"
                            android:textColor="@color/gray"
                            app:fontVariationSettings="'wght' 400"/>

                        <TextView
                            android:id="@+id/actualEC"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="@color/black"
                            app:fontVariationSettings="'wght' 600"/>
                    </LinearLayout>

                    <!-- Variable NPK -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginLeft="15dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NPK"
                            android:textColor="@color/gray"
                            app:fontVariationSettings="'wght' 400"/>

                        <TextView
                            android:id="@+id/actualNPK"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="@color/black"
                            app:fontVariationSettings="'wght' 600"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- Alertas de riesgo -->
            <LinearLayout
                android:layout_marginTop="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:paddingLeft="15dp"
                android:paddingRight="15dp"
                android:paddingBottom="10dp"
                android:orientation="vertical"
                android:background="@drawable/bg_input">

                <!-- Titulo - Header -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:src="@drawable/ic_bell"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alertas de riesgo"
                        android:textColor="@color/black"
                        app:fontVariationSettings="'wght' 700"
                        android:paddingTop="10dp"
                        android:paddingBottom="6dp"
                        android:paddingLeft="3dp"/>
                </LinearLayout>

                <!-- Notificacion -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_alert"
                    android:padding="10dp"
                    android:elevation="5dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_watering_can"
                        android:background="@drawable/bg_icon"
                        android:padding="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Cultivo con falta de agua"
                            android:textColor="@color/black"
                            app:fontVariationSettings="'wght' 700"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Hace 10 minutos"
                            android:textSize="12sp"
                            android:textColor="@color/gray"
                            app:fontVariationSettings="'wght' 400"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Notificacion -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_alert"
                    android:layout_marginTop="10dp"
                    android:padding="10dp"
                    android:elevation="5dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_cloud"
                        android:background="@drawable/bg_icon"
                        android:padding="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Habrá una día de nubes dur..."
                            android:textColor="@color/black"
                            app:fontVariationSettings="'wght' 700"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Hace 1 día"
                            android:textSize="12sp"
                            android:textColor="@color/gray"
                            app:fontVariationSettings="'wght' 400"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Boton para ir a ver alertas -->
                <Button
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ver alertas"
                    android:textColor="@color/white"
                    app:fontVariationSettings="'wght' 800"
                    android:background="@drawable/bg_button_green"
                    app:backgroundTint="@null"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

            <!-- Mis dispositivos -->
            <LinearLayout
                android:layout_marginTop="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:paddingLeft="15dp"
                android:paddingRight="15dp"
                android:paddingBottom="10dp"
                android:orientation="vertical"
                android:background="@drawable/bg_input">

                <!-- Titulo - Header -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:src="@drawable/ic_device_radar_big"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mis dispositivos"
                        android:textColor="@color/black"
                        app:fontVariationSettings="'wght' 700"
                        android:paddingTop="10dp"
                        android:paddingBottom="6dp"
                        android:paddingLeft="3dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Dispositivo -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_alert"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingLeft="3dp"
                            android:paddingRight="3dp"
                            android:src="@drawable/ic_device_sfv1"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                android:text="Estación de monitoreo 1"
                                android:textColor="@color/black"
                                app:fontVariationSettings="'wght' 700"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SF-SIGIV1"
                                android:textSize="12sp"
                                android:textColor="@color/gray"
                                app:fontVariationSettings="'wght' 400"/>

                            <Button
                                android:layout_width="match_parent"
                                android:layout_height="30dp"
                                android:text="conectado"
                                android:textColor="@color/white"
                                android:textSize="8dp"
                                app:fontVariationSettings="'wght' 800"
                                android:background="@drawable/bg_button_green"
                                app:backgroundTint="@null"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Dispositivo -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_alert"
                        android:layout_marginLeft="6dp"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingLeft="3dp"
                            android:paddingRight="3dp"
                            android:src="@drawable/ic_device_sfv1"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                android:text="Estación de monitoreo 2"
                                android:textColor="@color/black"
                                app:fontVariationSettings="'wght' 700"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SF-SIGIV1"
                                android:textSize="12sp"
                                android:textColor="@color/gray"
                                app:fontVariationSettings="'wght' 400"/>

                            <Button
                                android:layout_width="match_parent"
                                android:layout_height="30dp"
                                android:text="desconectado"
                                android:textColor="@color/white"
                                android:textSize="8dp"
                                app:fontVariationSettings="'wght' 800"
                                android:background="@drawable/bg_button_red"
                                app:backgroundTint="@null"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Boton para ir a ver dispositivos -->
                <Button
                    android:id="@+id/btnDevices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ver dispositivos"
                    android:textColor="@color/white"
                    app:fontVariationSettings="'wght' 800"
                    android:background="@drawable/bg_button_green"
                    app:backgroundTint="@null"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>

            <!-- Metricas -->
            <LinearLayout
                android:layout_marginTop="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:paddingLeft="15dp"
                android:paddingRight="15dp"
                android:paddingBottom="10dp"
                android:orientation="vertical"
                android:background="@drawable/bg_input">

                <!-- Titulo - Header -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:src="@drawable/ic_reports"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reportes"
                        android:textColor="@color/black"
                        app:fontVariationSettings="'wght' 700"
                        android:paddingTop="10dp"
                        android:paddingBottom="6dp"
                        android:paddingLeft="3dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Metrica variables -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_alert"
                        android:padding="20dp">

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="10dp"
                            android:src="@drawable/logo_metrics_variables"/>

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/logo_metrics_chart"/>

                    </LinearLayout>
                </LinearLayout>

                <!-- Boton para ir a ver las metricas -->
                <Button
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ver reportes"
                    android:textColor="@color/white"
                    app:fontVariationSettings="'wght' 800"
                    android:background="@drawable/bg_button_green"
                    app:backgroundTint="@null"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Footer -->
    <LinearLayout
        android:id="@+id/bottomNavLayout"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_gravity="bottom"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@color/white"
        android:elevation="4dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/navHomeContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/btnNavHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Inicio"
                app:tint="@color/darkGreen"
                android:src="@drawable/ic_home" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Inicio"
                android:textSize="10sp"
                android:textColor="@color/darkGreen"
                app:fontVariationSettings="'wght' 700"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navDevicesContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/btnNavDevices"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Dispositivos"
                android:src="@drawable/ic_device_radar_big" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Dispositivos"
                android:textSize="10sp"
                android:textColor="@color/black"
                app:fontVariationSettings="'wght' 700" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navFarmingContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/btnNavFarming"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Cultivos"
                android:src="@drawable/ic_fields_plantation" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Cultivos"
                android:textSize="10sp"
                android:textColor="@color/black"
                app:fontVariationSettings="'wght' 700" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettingsContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/btnNavSettings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Ajustes"
                android:src="@drawable/ic_settings" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Ajustes"
                android:textSize="10sp"
                android:textColor="@color/black"
                app:fontVariationSettings="'wght' 700" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>