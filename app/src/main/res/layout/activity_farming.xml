<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F0F0">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:fontVariationSettings="'wght' 700"
            android:background="#F0F0F0"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:id="@+id/layoutHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTituloPrincipal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cultivos"
                    app:fontVariationSettings="'wght' 700"
                    android:textColor="#1A1A1A"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/imgIconoHoja"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:contentDescription="Hoja"
                    android:src="@drawable/ic_leaf"
                    app:tint="#1A1A1A" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvNombreCultivo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:text="Cultivo de tomate cherry"
                app:fontVariationSettings="'wght' 700"
                android:textColor="#1A1A1A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/frameCarrusel"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_image_card"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/imgPrincipal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:contentDescription="Imagen cultivo"
                    android:scaleType="fitCenter"
                    android:src="@drawable/img_tomate_cherry" />

                <FrameLayout
                    android:id="@+id/btnAnterior"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_arrow_circle"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="‹"
                        android:textColor="#9C9C9C"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/btnSiguiente"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_arrow_circle"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="›"
                        android:textColor="#9C9C9C"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </FrameLayout>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/layoutChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/chipSol"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <FrameLayout
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_chip_icon_red">

                        <ImageView
                            android:id="@+id/imgIconoSol"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_gravity="center"
                            android:contentDescription="Sol"
                            android:src="@drawable/ic_sun"
                            app:tint="#FFFFFF" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvChipSolTitulo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pleno sol"
                            app:fontVariationSettings="'wght' 700"
                            android:textColor="#1A1A1A"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvChipSolSubtitulo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Iluminación"
                            app:fontVariationSettings="'wght' 700"
                            android:textColor="#9A9A9A"
                            android:textSize="8sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chipTemperatura"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <FrameLayout
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_chip_icon_orange">

                        <ImageView
                            android:id="@+id/imgIconoTemperatura"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_gravity="center"
                            android:contentDescription="Temperatura"
                            android:src="@drawable/ic_thermometer"
                            app:tint="#FFFFFF" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvChipTempTitulo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Medio seco"
                            app:fontVariationSettings="'wght' 700"
                            android:textColor="#1A1A1A"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvChipTempSubtitulo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Temperatura"
                            app:fontVariationSettings="'wght' 700"
                            android:textColor="#9A9A9A"
                            android:textSize="8sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chipHumedad"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="48dp"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <FrameLayout
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_chip_icon_blue">

                        <ImageView
                            android:id="@+id/imgIconoHumedad"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_gravity="center"
                            android:contentDescription="Humedad"
                            android:src="@drawable/ic_water_drop"
                            app:tint="#FFFFFF" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvChipHumedadTitulo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Seco"
                            app:fontVariationSettings="'wght' 700"
                            android:textColor="#1A1A1A"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvChipHumedadSubtitulo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Humedad"
                            app:fontVariationSettings="'wght' 700"
                            android:textColor="#9A9A9A"
                            android:textSize="8sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutHeaderAvances"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTituloAvances"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Imágenes de avance"
                    app:fontVariationSettings="'wght' 700"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnVerTodo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="Ver todo"
                    app:fontVariationSettings="'wght' 700"
                    android:textColor="#B4B4B4"
                    android:textSize="11sp" />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/scrollAvances"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:clipToPadding="false"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imgAvance1"
                        android:layout_width="65dp"
                        android:layout_height="60dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_thumb"
                        android:clickable="true"
                        android:contentDescription="Avance 1"
                        app:fontVariationSettings="'wght' 700"
                        android:focusable="true"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/plantacion_cherry" />

                    <ImageView
                        android:id="@+id/imgAvance2"
                        android:layout_width="65dp"
                        android:layout_height="60dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_thumb"
                        android:clickable="true"
                        android:contentDescription="Avance 2"
                        android:focusable="true"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/plantacion_cherry" />

                    <ImageView
                        android:id="@+id/imgAvance3"
                        android:layout_width="65dp"
                        android:layout_height="60dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_thumb"
                        android:clickable="true"
                        android:contentDescription="Avance 3"
                        android:focusable="true"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/plantacion_cherry" />

                    <ImageView
                        android:id="@+id/imgAvance4"
                        android:layout_width="65dp"
                        android:layout_height="60dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_thumb"
                        android:clickable="true"
                        android:contentDescription="Avance 4"
                        android:focusable="true"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/plantacion_cherry" />

                    <ImageView
                        android:id="@+id/imgAvance5"
                        android:layout_width="65dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_thumb"
                        android:clickable="true"
                        android:contentDescription="Avance 5"
                        android:focusable="true"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/plantacion_cherry" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvTituloInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Información general"
                app:fontVariationSettings="'wght' 700"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDescripcionCultivo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:lineSpacingExtra="4dp"
                app:fontVariationSettings="'wght' 700"
                android:text="El tomate cherry (o tomate cereza) es una variedad pequeña y redondeada del clásico tomate (Solanum lycopersicum). Su nombre proviene del inglés cherry (cereza), haciendo alusión a su diminuto tamaño. Se caracteriza por su sabor más dulce, su textura jugosa y su versatilidad en la cocina."
                android:textColor="#6E6E6E"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btnAnadirCultivo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_green_button"
                android:text="Añadir cultivo"
                app:fontVariationSettings="'wght' 700"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomNavLayout"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Inicio"
            android:focusable="true"
            android:src="@drawable/ic_home" />

        <ImageView
            android:id="@+id/btnNavSensor"
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Sensor"
            android:focusable="true"
            android:src="@drawable/ic_device_radar_big" />

        <ImageView
            android:id="@+id/btnNavCultivos"
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Cultivos"
            android:focusable="true"
            android:src="@drawable/ic_fields_plantation" />

        <ImageView
            android:id="@+id/btnNavAjustes"
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Ajustes"
            android:focusable="true"
            android:src="@drawable/ic_settings" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>