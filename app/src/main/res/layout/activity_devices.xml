<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgView"
    tools:context=".DevicesActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="135dp"
        android:padding="15dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dispositivos"
                    android:textColor="@color/black"
                    android:textSize="24sp"
                    app:fontVariationSettings="'wght' 700" />

                <ImageView
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:paddingLeft="8dp"
                    android:src="@drawable/ic_device_radar_big"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_input"
                android:padding="15dp"
                android:layout_marginBottom="15dp"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estación de monitoreo 1"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        app:fontVariationSettings="'wght' 700"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Invernadero 1 - SIGIV2"
                        android:textSize="12sp"
                        android:textColor="@color/gray"
                        app:fontVariationSettings="'wght' 400"
                        android:layout_marginBottom="15dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:layout_width="wrap_content"
                            android:layout_height="35dp"
                            android:text="ver dispositivo"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            app:fontVariationSettings="'wght' 800"
                            android:background="@drawable/bg_button_yellow"
                            app:backgroundTint="@null"
                            android:paddingHorizontal="15dp"/>

                        <Button
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:text="conectado"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            app:fontVariationSettings="'wght' 800"
                            android:background="@drawable/bg_button_green"
                            app:backgroundTint="@null"
                            android:layout_marginLeft="10dp"
                            android:paddingHorizontal="10dp"
                            android:clickable="false"/>
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="10dp"
                    android:src="@drawable/ic_device_sfv1"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_input"
                android:padding="15dp"
                android:layout_marginBottom="15dp"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estación de monitoreo 2"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        app:fontVariationSettings="'wght' 700"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Invernadero 1 - SIGIV2"
                        android:textSize="12sp"
                        android:textColor="@color/gray"
                        app:fontVariationSettings="'wght' 400"
                        android:layout_marginBottom="15dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:layout_width="wrap_content"
                            android:layout_height="35dp"
                            android:text="ver dispositivo"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            app:fontVariationSettings="'wght' 800"
                            android:background="@drawable/bg_button_yellow"
                            app:backgroundTint="@null"
                            android:paddingHorizontal="15dp"/>

                        <Button
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:text="desconectado"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            app:fontVariationSettings="'wght' 800"
                            android:background="@drawable/bg_button_red"
                            app:backgroundTint="@null"
                            android:layout_marginLeft="10dp"
                            android:paddingHorizontal="10dp"
                            android:clickable="false"/>
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="10dp"
                    android:src="@drawable/ic_device_sfv1"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <Button
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="75dp"
        android:layout_marginHorizontal="15dp"
        android:text="Agregar nuevo dispositivo"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:fontVariationSettings="'wght' 800"
        android:background="@drawable/bg_button_green"
        app:backgroundTint="@null"
        android:elevation="4dp"/>

    <!-- Footer -->
    <LinearLayout
        android:id="@+id/bottomNavLayout"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_gravity="bottom"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@color/white"
        android:elevation="4dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/navHomeContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/btnNavHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Inicio"
                android:src="@drawable/ic_home" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Inicio"
                android:textSize="10sp"
                android:textColor="@color/black"
                app:fontVariationSettings="'wght' 700"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navDevicesContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/btnNavDevices"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Dispositivos"
                app:tint="@color/darkGreen"
                android:src="@drawable/ic_device_radar_big" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Dispositivos"
                android:textSize="10sp"
                android:textColor="@color/darkGreen"
                app:fontVariationSettings="'wght' 700" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navFarmingContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/btnNavFarming"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Cultivos"
                android:src="@drawable/ic_fields_plantation" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Cultivos"
                android:textSize="10sp"
                android:textColor="@color/black"
                app:fontVariationSettings="'wght' 700" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettingsContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/btnNavSettings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Ajustes"
                android:src="@drawable/ic_settings" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Ajustes"
                android:textSize="10sp"
                android:textColor="@color/black"
                app:fontVariationSettings="'wght' 700" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>